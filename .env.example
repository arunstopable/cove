# Cove v3.0 — Environment configuration template
# Copy this file to .env and fill in your values.

# ── Debug mode ────────────────────────────────────────────────────────────────
# Set to 1 to enable verbose logging in sc_scraper and proxy
COVE_DEBUG=0

# ── StreamingCommunity ────────────────────────────────────────────────────────
# Anchor page used to auto-discover the current active SC domain.
# Only change this if the anchor page URL changes.
SC_ANCHOR_URL=https://www.streaming-community.co/

# ── Proxy server ──────────────────────────────────────────────────────────────
# IP address of the machine running proxy.py (your NAS / server / Mac).
# This is embedded in the .strm files that Jellyfin reads.
PROXY_SERVER_IP=192.168.1.120

# Port that proxy.py listens on.
PROXY_SERVER_PORT=8000

# ── Jellyfin library paths (NFS mount points) ─────────────────────────────────
# These must be mounted and writable when running the export command.
NFS_SHOWS_PATH=/Volumes/Logan/shows
NFS_MOVIES_PATH=/Volumes/Logan/movies

# ── Local player ──────────────────────────────────────────────────────────────
# Used by "Play locally" in the CLI.
# Supported values: IINA, VLC, mpv
PLAYER_APP=IINA
